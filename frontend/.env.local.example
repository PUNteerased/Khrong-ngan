# คัดลอกเป็น .env.local
NEXT_PUBLIC_API_URL=http://localhost:4000
# Production (Vercel): ชี้ไปที่ URL ของ API บน Render — ไม่ใส่ slash ท้าย
# NEXT_PUBLIC_API_URL=https://your-service.onrender.com

# --- Supabase Storage (ใช้อัปโหลดรูปภาพ) ---
# จาก Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# ชื่อ bucket (public) ที่สร้างใน Supabase Storage
NEXT_PUBLIC_SUPABASE_BUCKET=laneya-images

# Google Login — ตั้ง GOOGLE_CLIENT_ID ใน backend/.env (Render)
# Frontend ดึง client id จาก GET /api/auth/google-config อัตโนมัติ
# ถ้าต้องการ override ตอน dev: ใส่ค่าเดียวกับ backend
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Kiosk tablet display (/kiosk) ---
NEXT_PUBLIC_KIOSK_S3_URL=http://192.168.1.100
KIOSK_DISPLAY_TOKEN=change-me-kiosk-display
