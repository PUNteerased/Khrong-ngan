generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  username       String   @unique
  phone          String?
  passwordHash   String
  isAdmin        Boolean  @default(false)
  fullName       String
  age            Int?
  weight         Float?
  allergiesText  String   @default("")
  noAllergies    Boolean  @default(false)
  diseasesText   String   @default("")
  noDiseases     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  chatSessions   ChatSession[]
}

model Drug {
  id          String   @id @default(cuid())
  name        String
  description String
  slotId      String   @unique
  quantity    Int      @default(0)
  category    String?
  dosageNotes String?
  warnings    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  sessions    ChatSession[] @relation("RecommendedDrug")
}

enum PickupStatus {
  NONE
  QR_ISSUED
  PICKED
  EXPIRED
}

model ChatSession {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  difyConversationId String?
  summary            String?
  pickupStatus       PickupStatus @default(NONE)
  recommendedDrugId  String?
  recommendedDrug    Drug?        @relation("RecommendedDrug", fields: [recommendedDrugId], references: [id])
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  messages           ChatMessage[]
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  createdAt DateTime    @default(now())
}
