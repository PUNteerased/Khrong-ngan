generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// End-user account; health context for AI chat is stored on these fields (see allergiesText + noAllergies).
model User {
  id             String   @id @default(cuid())
  username       String   @unique
  phone          String?
  passwordHash   String
  isAdmin        Boolean  @default(false)
  fullName       String
  /// Public URL from Supabase Storage (or other CDN) for profile photo.
  avatarUrl      String?
  /// Age in full years, optional.
  age            Int?
  /// Body weight (kg), optional.
  weight         Float?
  /// Body height (cm), optional — used by AI for BMI-related dosing context.
  height         Float?
  /// Gender (e.g. "male", "female", "other") — optional. AI uses this for sex-specific dosing/red-flags.
  gender         String?
  /// Free-text drug allergy history (Thai/English); use with `noAllergies` when the user declares none.
  allergiesText  String   @default("")
  /// Normalized allergy keywords for strict safety matching, e.g. "penicillin,ibuprofen,amoxicillin".
  allergyKeywords String  @default("")
  noAllergies    Boolean  @default(false)
  diseasesText   String   @default("")
  noDiseases     Boolean  @default(false)
  /// Free-text list of drugs the user is currently taking (for drug-drug interaction screening).
  currentMedications String @default("")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  chatSessions   ChatSession[]
  adminReviews   AdminSessionReview[] @relation("AdminReviewer")
  auditLogsAsAdmin AdminAuditLog[]   @relation("AuditAdmin")
  auditLogsAsTarget AdminAuditLog[]  @relation("AuditTarget")
}

/// Medicine row in the cabinet; `imageUrl` is optional public URL for UI (Supabase Storage).
model Drug {
  id          String    @id @default(cuid())
  name        String
  description String
  slotId      String    @unique
  quantity    Int       @default(0)
  category    String?
  dosageNotes String?
  warnings    String?
  /// Comma-separated active ingredients for hard safety checks, e.g. "paracetamol,caffeine".
  ingredientsText String  @default("")
  /// Public URL for drug photo (e.g. Supabase `laneya-images` bucket).
  imageUrl    String?
  expiresAt   DateTime?
  priceCents  Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  sessions    ChatSession[] @relation("RecommendedDrug")
}

enum PickupStatus {
  NONE
  QR_ISSUED
  PICKED
  EXPIRED
}

enum ConsultationSeverity {
  ROUTINE
  ESCALATE_HOSPITAL
}

model ChatSession {
  id                   String                 @id @default(cuid())
  userId               String
  user                 User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  difyConversationId   String?
  summary              String?
  pickupStatus         PickupStatus           @default(NONE)
  recommendedDrugId  String?
  recommendedDrug      Drug?                @relation("RecommendedDrug", fields: [recommendedDrugId], references: [id])
  severity             ConsultationSeverity   @default(ROUTINE)
  redFlagReason        String?
  userProfileSnapshot  Json?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  messages             ChatMessage[]
  adminReview          AdminSessionReview?
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      String
  content   String
  imageUrl  String?
  createdAt DateTime    @default(now())
}

enum AdminFeedbackRating {
  UP
  DOWN
}

model AdminSessionReview {
  id          String               @id @default(cuid())
  sessionId   String               @unique
  session     ChatSession          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  adminUserId String?
  adminUser   User?                @relation("AdminReviewer", fields: [adminUserId], references: [id])
  rating      AdminFeedbackRating
  note        String?
  createdAt   DateTime             @default(now())
}

model AdminAuditLog {
  id            String   @id @default(cuid())
  adminUserId   String?
  adminUser     User?    @relation("AuditAdmin", fields: [adminUserId], references: [id])
  action        String
  targetUserId  String?
  targetUser    User?    @relation("AuditTarget", fields: [targetUserId], references: [id])
  payload       Json?
  createdAt     DateTime @default(now())
}
