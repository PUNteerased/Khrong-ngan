PORT=4000
# PostgreSQL (local / Render / Neon) — ตัวอย่าง:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laneya?schema=public"
JWT_SECRET=change-me-in-production-min-32-chars-long
# ต้องตรงกับ URL ของ Next.js (local หรือ https://xxx.vercel.app)
CORS_ORIGIN=http://localhost:3000

# Dify — เก็บเฉพาะใน backend (ไม่ส่งไป frontend)
DIFY_API_KEY=
DIFY_API_BASE=https://api.dify.ai/v1
# Chat App ใน Dify — ใช้เป็น default ถ้าไม่ส่งจาก client
DIFY_APP_ID=
# URL สำหรับตรวจสอบสถานะตู้จริง (เช่น http://192.168.1.50/health)
CABINET_HEALTH_URL=

# ผู้ดูแล — เข้า Admin ด้วย username + รหัสผ่านของ User ที่มี isAdmin=true
# หลังรัน `npm run db:seed` จะมีบัญชี seed (ค่าเริ่มต้นด้านล่าง — เปลี่ยนใน production)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=laneYa_admin_dev
# หรือตั้ง isAdmin เองใน Prisma Studio / SQL
# ถ้าแยก secret สำหรับ JWT ผู้ดูแล (ไม่ตั้ง = ใช้ JWT_SECRET)
ADMIN_JWT_SECRET=
# ทางเลือก: คีย์สำหรับสคริปต์/เครื่องมือเรียก API แก้ไขยา (ไม่ใช้ในเบราว์เซอร์)
ADMIN_API_KEY=

# Google Login (Backend verify Google ID token)
GOOGLE_CLIENT_ID=

# ส่งรหัส OTP ทางอีเมล (Resend)
RESEND_API_KEY=
# ผู้ส่ง เช่น LaneYa <no-reply@yourdomain.com>
RESEND_FROM_EMAIL=

# ส่งรหัส OTP ทาง SMS (ThaiBulkSMS)
THAIBULKSMS_API_KEY=
THAIBULKSMS_API_SECRET=
# ตั้งค่าเมื่อ package ของบัญชีรองรับ Sender Name
THAIBULKSMS_SENDER=
# ปรับได้เฉพาะกรณีใช้ endpoint พิเศษของผู้ให้บริการ
THAIBULKSMS_BASE_URL=https://otp.thaibulksms.com

# เกณฑ์ "ยาใกล้หมด" สำหรับแดชบอร์ดผู้ดูแล (จำนวนคงเหลือ > 0 และ <= ค่านี้)
LOW_STOCK_THRESHOLD=5
