PORT=4000
# PostgreSQL (local / Render / Neon) — ตัวอย่าง:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/laneya?schema=public"
JWT_SECRET=change-me-in-production-min-32-chars-long
# ต้องตรงกับ URL ของ Next.js (local หรือ https://xxx.vercel.app)
CORS_ORIGIN=http://localhost:3000

# Dify — เก็บเฉพาะใน backend (ไม่ส่งไป frontend)
DIFY_API_KEY=
DIFY_API_BASE=https://api.dify.ai/v1
# Chat App ใน Dify — ใช้เป็น default ถ้าไม่ส่งจาก client
DIFY_APP_ID=
# Published Google Sheet (โรค/อาการ/ยา + แท็บ mapping แยก + HealthTip + I18N_UI)
KNOWLEDGE_SHEET_PUBLISHED_URL=https://docs.google.com/spreadsheets/d/e/2PACX-1vSH7ovQx_3n4n_-e5chogXtbMg9__BmBmT11Vvv58XYJWbe7v4YrImkatKEv6jaT9oTjS6Pt_W-8--h/pubhtml
# ถ้าชื่อแท็บไม่ได้เป็น Disease/Symptom/Drug แบบเป๊ะ (มีช่องว่าง/ภาษาไทย/อักษรซ่อน)
KNOWLEDGE_SHEET_TAB_DISEASE=Disease
KNOWLEDGE_SHEET_TAB_SYMPTOM=Symptom
KNOWLEDGE_SHEET_TAB_DRUG=Drug
KNOWLEDGE_SHEET_TAB_MAP_DISEASE_SYMPTOM=Map_Disease_Symptom
KNOWLEDGE_SHEET_TAB_MAP_DISEASE_DRUG=Map_Disease_Drug
KNOWLEDGE_SHEET_TAB_MAP_SYMPTOM_DRUG=Map_Symptom_Drug
KNOWLEDGE_SHEET_TAB_HEALTH_TIP=HealthTip
KNOWLEDGE_SHEET_TAB_HEALTH_TIP_REF=HealthTip_Ref
KNOWLEDGE_SHEET_TAB_I18N_UI=I18N_UI
# ทางเลือก (แนะนำ): Google Sheets API v4
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_API_KEY=
# ถ้าตั้งชีทเป็น "Anyone with the link can view" (public view) สามารถใส่แค่ GOOGLE_SHEETS_ID
# แล้วระบบจะอ่านผ่าน gviz CSV โดยไม่ต้อง publish และไม่ต้องใช้ API key
# ทางเลือก production (แนะนำที่สุด): Service Account
# วิธีที่ 1: ใส่ JSON ทั้งก้อนเป็นบรรทัดเดียว
GOOGLE_SERVICE_ACCOUNT_JSON=
# วิธีที่ 2: ใส่แยก (private key ให้แทนขึ้นบรรทัดใหม่ด้วย \n)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# นโยบายเมื่อข้อมูลหายจากชีท: soft|hard (hard จะไม่ลบ Drug จริง)
SYNC_DELETE_MODE=soft
# ถ้า Drug tab มี drug_ref ที่ยังไม่มีใน DB ให้สร้าง Drug ใหม่อัตโนมัติ (quantity=0)
KNOWLEDGE_SYNC_CREATE_MISSING_DRUGS=0
# URL สำหรับตรวจสอบสถานะตู้จริง (เช่น http://192.168.1.50/health)
CABINET_HEALTH_URL=

# ผู้ดูแล — เข้า Admin ด้วย username + รหัสผ่านของ User ที่มี isAdmin=true
# หลังรัน `npm run db:seed` จะมีบัญชี seed (ค่าเริ่มต้นด้านล่าง — เปลี่ยนใน production)
ADMIN_SEED_USERNAME=admin
ADMIN_SEED_PASSWORD=laneYa_admin_dev
# หรือตั้ง isAdmin เองใน Prisma Studio / SQL
# ถ้าแยก secret สำหรับ JWT ผู้ดูแล (ไม่ตั้ง = ใช้ JWT_SECRET)
ADMIN_JWT_SECRET=
# ทางเลือก: คีย์สำหรับสคริปต์/เครื่องมือเรียก API แก้ไขยา (ไม่ใช้ในเบราว์เซอร์)
ADMIN_API_KEY=

# Google Login (Backend verify Google ID token)
GOOGLE_CLIENT_ID=

# ส่งรหัส OTP ทางอีเมล (Resend)
RESEND_API_KEY=
# ผู้ส่ง เช่น LaneYa <no-reply@yourdomain.com>
RESEND_FROM_EMAIL=

# ส่งรหัส OTP ทาง SMS (ThaiBulkSMS)
THAIBULKSMS_API_KEY=
THAIBULKSMS_API_SECRET=
# ตั้งค่าเมื่อ package ของบัญชีรองรับ Sender Name
THAIBULKSMS_SENDER=
# ปรับได้เฉพาะกรณีใช้ endpoint พิเศษของผู้ให้บริการ
THAIBULKSMS_BASE_URL=https://otp.thaibulksms.com

# เกณฑ์ "ยาใกล้หมด" สำหรับแดชบอร์ดผู้ดูแล (จำนวนคงเหลือ > 0 และ <= ค่านี้)
LOW_STOCK_THRESHOLD=5
